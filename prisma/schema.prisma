generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
}

model User {
  id              String           @id @default(uuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  role            Role?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  learningProfile LearningProfile?
  courses         Course[]
  progress        UserProgress[]
  studentProfiles StudentProfile[]
}

enum CourseStatus {
  DRAFT
  PROCESSING
  READY
  ERROR
}

enum ContentType {
  TEXT
  AUDIO
  QUIZ
  PODCAST
  VISUAL
  VIDEO
  INTERACTIVE
}

model Course {
  id               String          @id @default(uuid())
  title            String
  description      String?
  sourceMaterials  Json            @default("[]")
  creatorId        String
  creator          User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  status           CourseStatus    @default(DRAFT)
  generationError  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  contents         CourseContent[]
  progress         UserProgress[]
}

model StudentProfile {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  disabilities       Json     @default("[]")
  preferences        Json     @default("[]")
  accessibilityNeeds Json     @default("{}")
  outputModes        Json     @default("[]")
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  courses            Course[]

  @@map("student_profiles")
}

model CourseContent {
  id          String         @id @default(uuid())
  courseId     String
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contentType ContentType
  contentData Json
  metadata    Json           @default("{}")
  orderIndex  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  progress    UserProgress[]
}

model UserProgress {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contentId       String?
  content         CourseContent? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  completed       Boolean        @default(false)
  timeSpent       Int            @default(0)
  performanceData Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, courseId, contentId])
}

model LearningProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  disabilities       Json      @default("[]")
  preferences        Json      @default("[]")
  accessibilityNeeds Json      @default("{}")
  assessmentResults  Json      @default("{}")
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
